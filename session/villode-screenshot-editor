    def _refresh_tool_styles(self) -> None:
        for tid, btn in self.tool_buttons.items():
            if tid == self.tool:
                btn.add_css_class("active")
            else:
                btn.remove_css_class("active")

    def _refresh_color_styles(self) -> None:
        for c, btn in self.color_buttons.items():
            if c == self.color:
                btn.add_css_class("active")
            else:
                btn.remove_css_class("active")

    def _refresh_width_styles(self) -> None:
        nearest = min(self.width_buttons.keys(), key=lambda w: abs(w - self.line_width))
        for w, btn in self.width_buttons.items():
            if w == nearest:
                btn.add_css_class("active")
            else:
                btn.remove_css_class("active")

    def _on_tool_clicked(self, _btn: Gtk.Button, tid: str) -> None:
        self.tool = tid
        self._refresh_tool_styles()
        self._update_cursor()

    def _on_color_clicked(self, _btn: Gtk.Button, hex_c: str) -> None:
        self.color = hex_c
        self._refresh_color_styles()

    def _on_width_clicked(self, _btn: Gtk.Button, w: float) -> None:
        self.line_width = w
        self._refresh_width_styles()

    def _monitor_size(self) -> tuple[int, int]:
        disp = Gdk.Display.get_default()
        if not disp:
            return 1920, 1080
        mon = disp.get_monitors().get_item(0)
        if mon:
            g = mon.get_geometry()
            return g.width, g.height
        return 1920, 1080

    def _initial_layout(self) -> bool:
        mw, mh = self._monitor_size()
        # leave room for floating bars (~140px) and margins
        max_w = int(mw * 0.88)
        max_h = int(mh * 0.72)
        # Viewport is fixed once at open; later zoom only changes canvas content.
        fit_z = min(max_w / max(1, self.img_w), max_h / max(1, self.img_h), 1.0)
        self.zoom = max(self.min_zoom, fit_z * 0.98)
        self.viewport_w = max(160, min(int(self.img_w * self.zoom), max_w))
        self.viewport_h = max(120, min(int(self.img_h * self.zoom), max_h))
        self.scroll.set_size_request(self.viewport_w, self.viewport_h)
        self._apply_zoom_geometry()
        if not self._layer:
            self.fullscreen()
        return False


    def _update_zoom_label(self) -> None:
        self.zoom_label.set_text(f"{int(round(self.zoom * 100))}%")

    def _apply_zoom_geometry(self) -> None:
        # Only resize the drawing surface; keep scroll viewport fixed.
        self.da.set_content_width(max(1, int(self.img_w * self.zoom)))
        self.da.set_content_height(max(1, int(self.img_h * self.zoom)))
        if getattr(self, "viewport_w", 0) > 0 and getattr(self, "viewport_h", 0) > 0:
            self.scroll.set_size_request(self.viewport_w, self.viewport_h)
        self._update_zoom_label()
        self.da.queue_draw()

    def set_zoom(self, z: float, anchor: tuple[float, float] | None = None) -> None:
        z = max(self.min_zoom, min(self.max_zoom, z))
        if abs(z - self.zoom) < 1e-6:
            return
        old = self.zoom
        hadj = self.scroll.get_hadjustment()
        vadj = self.scroll.get_vadjustment()
        # Anchor is DrawingArea content coords (same as event x/y on da).
        if anchor is not None and old > 1e-6:
            ax, ay = anchor
            ix = ax / old
            iy = ay / old
            vx = ax - (hadj.get_value() if hadj else 0.0)
            vy = ay - (vadj.get_value() if vadj else 0.0)
        else:
            ix = iy = vx = vy = None  # type: ignore

        self.zoom = z
        self._apply_zoom_geometry()

        if ix is not None and hadj is not None and vadj is not None:
            nx = ix * z
            ny = iy * z
            max_x = max(0.0, hadj.get_upper() - hadj.get_page_size())
            max_y = max(0.0, vadj.get_upper() - vadj.get_page_size())
            hadj.set_value(max(0.0, min(max_x, nx - vx)))
            vadj.set_value(max(0.0, min(max_y, ny - vy)))

    def zoom_in(self) -> None:
        self.set_zoom(self.zoom * 1.15)

    def zoom_out(self) -> None:
        self.set_zoom(self.zoom / 1.15)

    def zoom_fit(self) -> None:
        # Refit image into the existing fixed viewport (do not grow window).
        vw = max(1, getattr(self, "viewport_w", 640))
        vh = max(1, getattr(self, "viewport_h", 360))
        z = min(vw / max(1, self.img_w), vh / max(1, self.img_h), 1.0)
        self.set_zoom(max(self.min_zoom, z * 0.98))

    def _on_scroll(self, controller: Gtk.EventControllerScroll, _dx: float, dy: float) -> bool:
        if dy == 0:
            return False
        # Zoom toward pointer when possible
        anchor = None
        try:
            widget = controller.get_widget()
            # Prefer last known pointer on drawing area
            if widget is self.da and hasattr(self, "_last_pointer"):
                anchor = self._last_pointer
            elif widget is self.scroll and hasattr(self, "_last_pointer"):
                # convert viewport-ish: last_pointer already in da content coords
                anchor = self._last_pointer
        except Exception:
            anchor = None
        factor = 1.12 if dy < 0 else 1 / 1.12
        self.set_zoom(self.zoom * factor, anchor=anchor)
        return True

    def _view_to_img(self, x: float, y: float) -> tuple[float, float]:
        z = self.zoom if self.zoom > 1e-6 else 1.0
        return (
            max(0.0, min(self.img_w - 1, x / z)),
            max(0.0, min(self.img_h - 1, y / z)),
        )

    def _viewport_pos(self, x: float, y: float) -> tuple[float, float]:
        """DrawingArea event → viewport-relative pos (stable when only scroll changes)."""
        hadj = self.scroll.get_hadjustment()
        vadj = self.scroll.get_vadjustment()
        hx = float(hadj.get_value()) if hadj else 0.0
        hy = float(vadj.get_value()) if vadj else 0.0
        return (float(x) - hx, float(y) - hy)

    def _begin_pan(self, x: float, y: float) -> None:
        """Pan with viewport-relative origin so scroll feedback cannot jitter."""
        self._panning = True
        self._moving = None
        self.drawing = False
        self.current = None
        hadj = self.scroll.get_hadjustment()
        vadj = self.scroll.get_vadjustment()
        self._pan_scroll0 = (
            float(hadj.get_value()) if hadj else 0.0,
            float(vadj.get_value()) if vadj else 0.0,
        )
        # origin in viewport space at press
        self._pan_origin = (float(x) - self._pan_scroll0[0], float(y) - self._pan_scroll0[1])
        self.da.set_cursor(Gdk.Cursor.new_from_name("grabbing"))

    def _end_pan(self) -> None:
        self._panning = False
        self._pan_origin = None
        self._update_cursor()

    def _update_cursor(self) -> None:
        if self.tool == "text":
            name = "text"
        elif self.tool == "eraser":
            name = "cell"
        else:
            name = "crosshair"
        self.da.set_cursor(Gdk.Cursor.new_from_name(name))

    def _on_pan_press(self, _g: Gtk.GestureClick, _n: int, x: float, y: float) -> None:
        self._begin_pan(x, y)

    def _on_pan_release(self, *_a: Any) -> None:
        self._end_pan()

    def _stroke_center(self, s: Stroke) -> tuple[float, float]:
        if not s.points:
            return (0.0, 0.0)
        xs = [p[0] for p in s.points]
        ys = [p[1] for p in s.points]
        return ((min(xs) + max(xs)) / 2.0, (min(ys) + max(ys)) / 2.0)

    def _world_to_local(self, s: Stroke, x: float, y: float) -> tuple[float, float]:
        cx, cy = self._stroke_center(s)
        x -= cx
        y -= cy
        # inverse rotate
        a = -s.angle
        cos_a, sin_a = math.cos(a), math.sin(a)
        x, y = x * cos_a - y * sin_a, x * sin_a + y * cos_a
        if s.flip_h:
            x = -x
        if s.flip_v:
            y = -y
        return (x + cx, y + cy)

    def _push_stroke_transform(self, cr: cairo.Context, s: Stroke) -> None:
        cx, cy = self._stroke_center(s)
        cr.translate(cx, cy)
        cr.rotate(s.angle)
        sx = -1.0 if s.flip_h else 1.0
        sy = -1.0 if s.flip_v else 1.0
        if sx != 1.0 or sy != 1.0:
            cr.scale(sx, sy)
        cr.translate(-cx, -cy)

    def rotate_cw(self) -> None:
        self._nudge_selected_angle(math.radians(15))

    def rotate_ccw(self) -> None:
        self._nudge_selected_angle(-math.radians(15))

    def _nudge_selected_angle(self, delta: float) -> None:
        s = self._selected
        if s is None or s not in self.strokes:
            return
        if s.tool not in ("text", "arrow", "rect", "ellipse", "pen", "mosaic"):
            return
        s.angle = (s.angle + delta) % math.tau
        self.redo_stack.clear()
        self._dirty = True
        self.da.queue_draw()

    def flip_horizontal(self) -> None:
        s = self._selected
        if s is None or s not in self.strokes:
            return
        s.flip_h = not s.flip_h
        self.redo_stack.clear()
        self._dirty = True
        self.da.queue_draw()

    def flip_vertical(self) -> None:
        s = self._selected
        if s is None or s not in self.strokes:
            return
        s.flip_v = not s.flip_v
        self.redo_stack.clear()
        self._dirty = True
        self.da.queue_draw()

    def _stroke_bounds(self, s: Stroke) -> tuple[float, float, float, float]:
        if not s.points:
            return (0, 0, 0, 0)
        if s.tool == "text":
            x, y = s.points[0]
            # approximate text box for hit testing
            size = max(12.0, s.width * 5)
            w = max(24.0, len(s.text) * size * 0.55)
            h = size * 1.2
            return (x - 4, y - h, x + w + 4, y + 8)
        xs = [p[0] for p in s.points]
        ys = [p[1] for p in s.points]
        pad = max(8.0, s.width * 2)
        return (min(xs) - pad, min(ys) - pad, max(xs) + pad, max(ys) + pad)

    def _hit_stroke(self, ix: float, iy: float, tools: set[str] | None = None) -> Stroke | None:
        for s in reversed(self.strokes):
            if tools is not None and s.tool not in tools:
                continue
            lx, ly = self._world_to_local(s, ix, iy)
            if s.tool == "text":
                x1, y1, x2, y2 = self._stroke_bounds(s)
                if x1 <= lx <= x2 and y1 <= ly <= y2:
                    return s
            elif s.tool == "arrow":
                if len(s.points) < 2:
                    continue
                x1, y1 = s.points[0]
                x2, y2 = s.points[-1]
                dx, dy = x2 - x1, y2 - y1
                L2 = dx * dx + dy * dy
                if L2 < 1e-6:
                    dist = math.hypot(lx - x1, ly - y1)
                else:
                    tt = max(0.0, min(1.0, ((lx - x1) * dx + (ly - y1) * dy) / L2))
                    px, py = x1 + tt * dx, y1 + tt * dy
                    dist = math.hypot(lx - px, ly - py)
                if dist <= max(10.0, s.width * 3):
                    return s
            else:
                x1, y1, x2, y2 = self._stroke_bounds(s)
                if x1 <= lx <= x2 and y1 <= ly <= y2:
                    if s.tool == "pen":
                        thr = max(8.0, s.width * 2.5)
                        if any(math.hypot(lx - px, ly - py) <= thr for px, py in s.points):
                            return s
                    else:
                        return s
        return None

    def _translate_stroke(self, s: Stroke, dx: float, dy: float) -> None:
        s.points = [(px + dx, py + dy) for px, py in s.points]

    def _erase_at(self, ix: float, iy: float) -> bool:
        hit = self._hit_stroke(ix, iy)
        if hit is None:
            return False
        self.strokes.remove(hit)
        if self._selected is hit:
            self._selected = None
        self.redo_stack.clear()
        self._dirty = True
        self.da.queue_draw()
        return True

    def clear_all(self) -> None:
        if not self.strokes:
            return
        # store as one undo unit by pushing a marker stroke? simpler: push all as one redo bundle
        self.redo_stack.append(Stroke(tool="__bundle__", color="", width=0, points=[], text=""))
        # stash previous strokes in a side list on the marker via text json? use points count hack:
        # Keep a parallel stack for bundles
        if not hasattr(self, "_bundle_stack"):
            self._bundle_stack: list[list[Stroke]] = []
        self._bundle_stack.append(list(self.strokes))
        self.strokes.clear()
        self._selected = None
        self._dirty = True
        self.da.queue_draw()

    def _on_press(self, _g: Gtk.GestureClick, _n: int, x: float, y: float) -> None:
        self._last_pointer = (x, y)
        if self.text_popover and self.text_popover.get_visible():
            return
        if self._space_down:
            self._begin_pan(x, y)
            return

        ix, iy = self._view_to_img(x, y)

        if self.tool == "eraser":
            self.drawing = True
            self._erase_at(ix, iy)
            return

        # Prefer moving existing text/arrow (topmost hit)
        hit = self._hit_stroke(ix, iy, tools={"text", "arrow"})
        if hit is not None and self.tool != "text":
            self._moving = hit
            self._selected = hit
            self._move_last = (ix, iy)
            self.drawing = False
            self.current = None
            self.da.set_cursor(Gdk.Cursor.new_from_name("grabbing"))
            self.da.queue_draw()
            return

        self.drawing = True
        self.redo_stack.clear()
        self._selected = None
        self._moving = None

        if self.tool == "text":
            self.drawing = False
            self._start_text(ix, iy, x, y)
            return

        self.current = Stroke(tool=self.tool, color=self.color, width=self.line_width, points=[(ix, iy)])
        if self.tool == "mosaic":
            self.current.mosaic = max(6, int(self.line_width * 3))
        self.da.queue_draw()

    def _on_motion(self, _c: Gtk.EventControllerMotion, x: float, y: float) -> None:
        self._last_pointer = (x, y)

        if self._panning and self._pan_origin is not None:
            # event (x,y) is content coords; convert to viewport-relative
            hadj = self.scroll.get_hadjustment()
            vadj = self.scroll.get_vadjustment()
            hx = float(hadj.get_value()) if hadj else 0.0
            hy = float(vadj.get_value()) if vadj else 0.0
            cur_vp = (float(x) - hx, float(y) - hy)
            dx = cur_vp[0] - self._pan_origin[0]
            dy = cur_vp[1] - self._pan_origin[1]
            if hadj:
                max_x = max(0.0, hadj.get_upper() - hadj.get_page_size())
                hadj.set_value(max(0.0, min(max_x, self._pan_scroll0[0] - dx)))
            if vadj:
                max_y = max(0.0, vadj.get_upper() - vadj.get_page_size())
                vadj.set_value(max(0.0, min(max_y, self._pan_scroll0[1] - dy)))
            return

        if self._moving is not None and self._move_last is not None:
            ix, iy = self._view_to_img(x, y)
            dx = ix - self._move_last[0]
            dy = iy - self._move_last[1]
            if abs(dx) > 1e-6 or abs(dy) > 1e-6:
                self._translate_stroke(self._moving, dx, dy)
                self._move_last = (ix, iy)
                self._dirty = True
                self.da.queue_draw()
            return

        if self.tool == "eraser" and self.drawing:
            ix, iy = self._view_to_img(x, y)
            self._erase_at(ix, iy)
            return

        if not self.drawing or not self.current:
            return
        ix, iy = self._view_to_img(x, y)
        if self.current.tool == "pen":
            self.current.points.append((ix, iy))
        else:
            if len(self.current.points) == 1:
                self.current.points.append((ix, iy))
            else:
                self.current.points[-1] = (ix, iy)
        self.da.queue_draw()

    def _on_release(self, _g: Gtk.GestureClick, _n: int, x: float, y: float) -> None:
        if self._panning and not self._space_down:
            self._end_pan()
            return

        if self._moving is not None:
            self.redo_stack.clear()
            self._moving = None
            self._move_last = None
            self._update_cursor()
            self.da.queue_draw()
            return

        if self.tool == "eraser":
            self.drawing = False
            return

        if not self.drawing or not self.current:
            self.drawing = False
            return
        ix, iy = self._view_to_img(x, y)
        if self.current.tool == "pen":
            self.current.points.append((ix, iy))
        else:
            if len(self.current.points) == 1:
                self.current.points.append((ix, iy))
            else:
                self.current.points[-1] = (ix, iy)
            x1, y1 = self.current.points[0]
            x2, y2 = self.current.points[-1]
            if abs(x2 - x1) < MIN_SHAPE and abs(y2 - y1) < MIN_SHAPE:
                self.current = None
                self.drawing = False
                self.da.queue_draw()
                return

        self.strokes.append(self.current)
        if self.current.tool in ("text", "arrow"):
            self._selected = self.current
        self.current = None
        self.drawing = False
        self._dirty = True
        self.da.queue_draw()

    def _start_text(self, ix: float, iy: float, vx: float, vy: float) -> None:
        entry = Gtk.Entry()
        entry.set_placeholder_text("输入文字，Enter 确认")
        entry.set_width_chars(28)
        pop = Gtk.Popover()
        pop.set_parent(self.da)
        pop.set_child(entry)
        rect = Gdk.Rectangle()
        rect.x, rect.y, rect.width, rect.height = int(vx), int(vy), 1, 1
        pop.set_pointing_to(rect)
        pop.set_autohide(True)

        def commit(*_a: Any) -> None:
            text = entry.get_text().strip()
            pop.popdown()
            if text:
                self.strokes.append(
                    Stroke(tool="text", color=self.color, width=self.line_width, points=[(ix, iy)], text=text)
                )
                self.redo_stack.clear()
                self._dirty = True
                self.da.queue_draw()
            self.text_popover = None

        entry.connect("activate", commit)
        pop.connect("closed", lambda *_: setattr(self, "text_popover", None))
        self.text_popover = pop
        pop.popup()
        entry.grab_focus()

    def _on_key(self, _c: Gtk.EventControllerKey, keyval: int, _code: int, state: Gdk.ModifierType) -> bool:
        ctrl = bool(state & Gdk.ModifierType.CONTROL_MASK)
        if keyval == Gdk.KEY_space:
            self._space_down = True
            self.da.set_cursor(Gdk.Cursor.new_from_name("grab"))
            return True
        if keyval == Gdk.KEY_Escape:
            if self.text_popover and self.text_popover.get_visible():
                self.text_popover.popdown()
                return True
            if self._selected is not None:
                self._selected = None
                self.da.queue_draw()
                return True
            self.close()
            return True
        if keyval in (Gdk.KEY_Delete, Gdk.KEY_BackSpace) and self._selected is not None:
            if self._selected in self.strokes:
                self.strokes.remove(self._selected)
                self.redo_stack.clear()
                self._dirty = True
            self._selected = None
            self.da.queue_draw()
            return True
        if self._selected is not None:
            if keyval in (Gdk.KEY_bracketleft,):
                self.rotate_ccw()
                return True
            if keyval in (Gdk.KEY_bracketright,):
                self.rotate_cw()
                return True
            if keyval in (Gdk.KEY_h, Gdk.KEY_H) and not ctrl:
                self.flip_horizontal()
                return True
            if keyval in (Gdk.KEY_v, Gdk.KEY_V) and not ctrl:
                self.flip_vertical()
                return True
        if ctrl and keyval in (Gdk.KEY_z, Gdk.KEY_Z):
            self.redo() if state & Gdk.ModifierType.SHIFT_MASK else self.undo()
            return True
        if ctrl and keyval in (Gdk.KEY_y, Gdk.KEY_Y):
            self.redo()
            return True
        if ctrl and keyval in (Gdk.KEY_s, Gdk.KEY_S):
            self.save_file()
            return True
        if ctrl and keyval in (Gdk.KEY_c, Gdk.KEY_C):
            self.copy_clipboard()
            return True
        if ctrl and keyval in (Gdk.KEY_equal, Gdk.KEY_plus, Gdk.KEY_KP_Add):
            self.zoom_in()
            return True
        if ctrl and keyval in (Gdk.KEY_minus, Gdk.KEY_KP_Subtract):
            self.zoom_out()
            return True
        if ctrl and keyval in (Gdk.KEY_0, Gdk.KEY_KP_0):
            self.zoom_fit()
            return True
        if keyval == Gdk.KEY_Return and not (self.text_popover and self.text_popover.get_visible()):
            self.finish()
            return True
        return False

    def _on_key_release(self, _c: Gtk.EventControllerKey, keyval: int, _code: int, _state: Gdk.ModifierType) -> bool:
        if keyval == Gdk.KEY_space:
            self._space_down = False
            if not self._panning:
                self._update_cursor()
            return True
        return False

    def undo(self) -> None:
        if not hasattr(self, "_bundle_stack"):
            self._bundle_stack = []
        if self.strokes:
            self.redo_stack.append(self.strokes.pop())
            self._selected = None
            self._dirty = True
            self.da.queue_draw()
            return
        # undo clear-all
        if self.redo_stack and self.redo_stack[-1].tool == "__bundle__" and self._bundle_stack:
            self.redo_stack.pop()
            self.strokes = self._bundle_stack.pop()
            self._selected = None
            self._dirty = True
            self.da.queue_draw()

    def redo(self) -> None:
        if not self.redo_stack:
            return
        item = self.redo_stack[-1]
        if item.tool == "__bundle__":
            # cannot easily redo clear without storing inverse; ignore
            return
        self.strokes.append(self.redo_stack.pop())
        self._dirty = True
        self.da.queue_draw()

    def finish(self) -> None:
        self.copy_clipboard()
        self.close()

    def _draw_stroke(self, cr: cairo.Context, s: Stroke) -> None:
        if not s.points:
            return
        r, g, b = parse_color(s.color)
        cr.save()
        if s.angle or s.flip_h or s.flip_v:
            self._push_stroke_transform(cr, s)
        cr.set_source_rgba(r, g, b, 1.0)
        cr.set_line_width(s.width)
        cr.set_line_cap(cairo.LINE_CAP_ROUND)
        cr.set_line_join(cairo.LINE_JOIN_ROUND)

        if s.tool == "pen":
            if len(s.points) == 1:
                x, y = s.points[0]
                cr.arc(x, y, s.width / 2, 0, math.tau)
                cr.fill()
            else:
                cr.move_to(*s.points[0])
                for p in s.points[1:]:
                    cr.line_to(*p)
                cr.stroke()
            cr.restore()
            return

        if s.tool == "text":
            cr.select_font_face("Sans", cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_BOLD)
            cr.set_font_size(max(12, s.width * 5))
            x, y = s.points[0]
            cr.set_source_rgba(0, 0, 0, 0.55)
            for dx, dy in ((-1, 0), (1, 0), (0, -1), (0, 1)):
                cr.move_to(x + dx, y + dy)
                cr.show_text(s.text)
            cr.set_source_rgba(r, g, b, 1.0)
            cr.move_to(x, y)
            cr.show_text(s.text)
            cr.restore()
            return

        if s.tool == "mosaic":
            x1, y1 = s.points[0]
            x2, y2 = s.points[-1]
            left, top = int(min(x1, x2)), int(min(y1, y2))
            right, bottom = int(max(x1, x2)), int(max(y1, y2))
            cell = max(4, s.mosaic)
            n_ch = self.pixbuf.get_n_channels()
            rowstride = self.pixbuf.get_rowstride()
            pixels = self.pixbuf.get_pixels()
            for yy in range(top, bottom, cell):
                for xx in range(left, right, cell):
                    cw = min(cell, right - xx)
                    ch = min(cell, bottom - yy)
                    if cw <= 0 or ch <= 0:
                        continue
                    sx = min(self.img_w - 1, xx + cw // 2)
                    sy = min(self.img_h - 1, yy + ch // 2)
                    idx = sy * rowstride + sx * n_ch
                    pr, pg, pb = pixels[idx] / 255.0, pixels[idx + 1] / 255.0, pixels[idx + 2] / 255.0
                    cr.set_source_rgb(pr, pg, pb)
                    cr.rectangle(xx, yy, cw, ch)
                    cr.fill()
            cr.restore()
            return

        x1, y1 = s.points[0]
        x2, y2 = s.points[-1]
        if s.tool == "rect":
            cr.rectangle(min(x1, x2), min(y1, y2), abs(x2 - x1), abs(y2 - y1))
            cr.stroke()
        elif s.tool == "ellipse":
            cx, cy = (x1 + x2) / 2, (y1 + y2) / 2
            rx, ry = abs(x2 - x1) / 2, abs(y2 - y1) / 2
            if rx >= 0.5 and ry >= 0.5:
                cr.save()
                cr.translate(cx, cy)
                cr.scale(rx, ry)
                cr.arc(0, 0, 1, 0, math.tau)
                cr.restore()
                cr.stroke()
        elif s.tool == "arrow":
            cr.move_to(x1, y1)
            cr.line_to(x2, y2)
            cr.stroke()
            angle = math.atan2(y2 - y1, x2 - x1)
            head = max(10.0, s.width * 4)
            a1 = angle + math.pi * 0.82
            a2 = angle - math.pi * 0.82
            cr.move_to(x2, y2)
            cr.line_to(x2 + head * math.cos(a1), y2 + head * math.sin(a1))
            cr.line_to(x2 + head * math.cos(a2), y2 + head * math.sin(a2))
            cr.close_path()
            cr.fill()
        cr.restore()

    def _draw(self, _area: Gtk.DrawingArea, cr: cairo.Context, _w: int, _h: int) -> None:
        br, bg, bb = parse_color(hx(self.theme["background"]))
        cr.set_source_rgb(br, bg, bb)
        cr.paint()
        cr.save()
        cr.scale(self.zoom, self.zoom)
        Gdk.cairo_set_source_pixbuf(cr, self.pixbuf, 0, 0)
        cr.paint()
        for s in self.strokes:
            self._draw_stroke(cr, s)
        if self.current:
            self._draw_stroke(cr, self.current)
        if self._selected is not None and self._selected in self.strokes:
            s = self._selected
            cr.save()
            if s.angle or s.flip_h or s.flip_v:
                self._push_stroke_transform(cr, s)
            x1, y1, x2, y2 = self._stroke_bounds(s)
            cr.set_source_rgba(0.66, 0.79, 0.91, 0.9)
            cr.set_line_width(1.0 / max(self.zoom, 0.01))
            cr.set_dash([4.0 / max(self.zoom, 0.01), 3.0 / max(self.zoom, 0.01)])
            cr.rectangle(x1, y1, x2 - x1, y2 - y1)
            cr.stroke()
            cr.set_dash([])
            cr.restore()
        cr.restore()

    def _render_to_pixbuf(self) -> GdkPixbuf.Pixbuf:
        surface = cairo.ImageSurface(cairo.FORMAT_ARGB32, self.img_w, self.img_h)
        cr = cairo.Context(surface)
        Gdk.cairo_set_source_pixbuf(cr, self.pixbuf, 0, 0)
        cr.paint()
        for s in self.strokes:
            self._draw_stroke(cr, s)
        surface.flush()
        buf = surface.get_data()
        rowstride = self.img_w * 4
        dest = bytearray(self.img_h * rowstride)
        src_stride = surface.get_stride()
        for y in range(self.img_h):
            for x in range(self.img_w):
                si = y * src_stride + x * 4
                b, g, r, a = buf[si], buf[si + 1], buf[si + 2], buf[si + 3]
                di = y * rowstride + x * 4
                dest[di], dest[di + 1], dest[di + 2], dest[di + 3] = r, g, b, a
        return GdkPixbuf.Pixbuf.new_from_data(
            bytes(dest), GdkPixbuf.Colorspace.RGB, True, 8, self.img_w, self.img_h, rowstride
        )

    def _write_png(self, path: Path) -> None:
        self._render_to_pixbuf().savev(str(path), "png", [], [])

    def copy_clipboard(self) -> None:
        tmp = Path(tempfile.mktemp(prefix="villode-ss-", suffix=".png"))
        try:
            self._write_png(tmp)
            with open(tmp, "rb") as f:
                subprocess.run(["wl-copy", "--type", "image/png"], stdin=f, check=False)
            self._toast("已复制到剪贴板")
            self._dirty = False
        except Exception as e:
            self._toast(f"复制失败：{e}")
        finally:
            try:
                tmp.unlink(missing_ok=True)
            except Exception:
                pass

    def save_file(self) -> None:
        SAVE_DIR.mkdir(parents=True, exist_ok=True)
        dest = SAVE_DIR / datetime.now().strftime("%Y-%m-%d-%H-%M-%S.png")
        try:
            self._write_png(dest)
            with open(dest, "rb") as f:
                subprocess.run(["wl-copy", "--type", "image/png"], stdin=f, check=False)
            self._toast(f"已保存：{dest}")
            self._dirty = False
        except Exception as e:
            self._toast(f"保存失败：{e}")

    def _toast(self, msg: str) -> None:
        try:
            subprocess.Popen(
                ["notify-send", "-a", "villode-screenshot", "-i", "image-x-generic", "截图", msg],
                start_new_session=True,
            )
        except Exception:
            pass


class App(Gtk.Application):
    def __init__(self, image_path: Path | None = None, daemon: bool = False):
        # Unique id per one-shot instance so multiple windows can open;
        # daemon keeps a single application alive.
        app_id = "local.villode.screenshot.editor" if daemon else f"local.villode.screenshot.editor.t{os.getpid()}"
        super().__init__(application_id=app_id)
        self.image_path = image_path
        self.daemon = daemon
        self.connect("activate", self.on_activate)

    def on_activate(self, app: Gtk.Application) -> None:
        if self.image_path is not None:
            Editor(app, self.image_path).present()
            self.image_path = None

    def open_path(self, path: Path) -> None:
        Editor(self, path).present()


SOCK_PATH = Path(os.environ.get("XDG_RUNTIME_DIR", f"/tmp/runtime-{os.getuid()}")) / "villode-screenshot-editor.sock"


def try_send_to_daemon(path: Path) -> bool:
    import socket
    if not SOCK_PATH.exists():
        return False
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(0.25)
        s.connect(str(SOCK_PATH))
        s.sendall((str(path.resolve()) + "\n").encode())
        # wait brief ack
        s.settimeout(0.5)
        try:
            s.recv(8)
        except Exception:
            pass
        s.close()
        return True
    except Exception:
        return False


def serve_daemon() -> int:
    import socket
    import threading

    SOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    try:
        if SOCK_PATH.exists():
            SOCK_PATH.unlink()
    except Exception:
        pass

    app = App(daemon=True)
    # Hold application open with no windows
    app.hold()

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(str(SOCK_PATH))
    server.listen(8)
    server.setblocking(False)

    def accept_cb(*_a):
        try:
            while True:
                try:
                    conn, _ = server.accept()
                except BlockingIOError:
                    break
                try:
                    data = b""
                    conn.settimeout(1.0)
                    while b"\n" not in data:
                        chunk = conn.recv(4096)
                        if not chunk:
                            break
                        data += chunk
                    line = data.decode(errors="replace").strip()
                    conn.sendall(b"ok\n")
                    conn.close()
                    if line:
                        path = Path(line).expanduser()
                        if path.is_file():
                            GLib.idle_add(lambda p=path: (app.open_path(p), False)[1])
                except Exception:
                    try:
                        conn.close()
                    except Exception:
                        pass
        except Exception:
            pass
        return True

    GLib.io_add_watch(server.fileno(), GLib.IO_IN, accept_cb)
    # Also present nothing — just run
    return app.run(None)


def main() -> int:
    args = sys.argv[1:]
    if not args:
        print("Usage: villode-screenshot-editor <image.png> | --daemon", file=sys.stderr)
        return 2
    if args[0] in ("--daemon", "-d"):
        return serve_daemon()

    path = Path(args[0]).expanduser()
    if not path.is_file():
        print(f"File not found: {path}", file=sys.stderr)
        return 1

    # Prefer warm daemon (near-instant); fall back to cold start
    if try_send_to_daemon(path):
        return 0
    return App(path).run(None)


if __name__ == "__main__":
    raise SystemExit(main())
