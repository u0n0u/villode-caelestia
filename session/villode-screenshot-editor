def load_theme() -> dict[str, str]:
    defaults = {
        "background": "0b0e11",
        "surface": "0b0e11",
        "surfaceContainer": "151a1f",
        "surfaceContainerHigh": "1b2025",
        "surfaceContainerHighest": "20262c",
        "onSurface": "e0e6ee",
        "onSurfaceVariant": "a5acb3",
        "outline": "70767d",
        "outlineVariant": "42494f",
        "primary": "a9cae8",
        "onPrimary": "22435c",
        "primaryContainer": "35566f",
        "error": "fa746f",
        "shadow": "000000",
    }
    try:
        data = json.loads(SCHEME_PATH.read_text())
        colours = data.get("colours") or data.get("colors") or {}
        for k in defaults:
            if k in colours and colours[k]:
                defaults[k] = str(colours[k]).lstrip("#")
    except Exception:
        pass
    return defaults


def hx(c: str) -> str:
    c = str(c).lstrip("#")
    return f"#{c}"


def parse_color(hex_color: str) -> tuple[float, float, float]:
    h = hex_color.lstrip("#")
    return tuple(int(h[i : i + 2], 16) / 255.0 for i in (0, 2, 4))  # type: ignore[return-value]


@dataclass
class Stroke:
    tool: str
    color: str
    width: float
    points: list[tuple[float, float]] = field(default_factory=list)
    text: str = ""
    mosaic: int = 12
    angle: float = 0.0  # radians
    flip_h: bool = False
    flip_v: bool = False


