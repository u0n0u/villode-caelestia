    def _setup_shell(self) -> None:
        """Undecorated fullscreen overlay (layer-shell if available)."""
        self._layer = False
        if HAS_LAYER and LayerShell.is_supported():
            LayerShell.init_for_window(self)
            LayerShell.set_layer(self, LayerShell.Layer.OVERLAY)
            LayerShell.set_anchor(self, LayerShell.Edge.TOP, True)
            LayerShell.set_anchor(self, LayerShell.Edge.BOTTOM, True)
            LayerShell.set_anchor(self, LayerShell.Edge.LEFT, True)
            LayerShell.set_anchor(self, LayerShell.Edge.RIGHT, True)
            LayerShell.set_keyboard_mode(self, LayerShell.KeyboardMode.EXCLUSIVE)
            LayerShell.set_namespace(self, "villode-screenshot")
            self._layer = True
            return

        # Fallback: undecorated window sized to the monitor (Hypr rules pin/float it)
        mw, mh = self._monitor_size()
        self.set_default_size(mw, mh)
        try:
            self.fullscreen()
        except Exception:
            pass

