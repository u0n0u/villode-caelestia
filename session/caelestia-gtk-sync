#!/usr/bin/env bash
# Sync system GTK apps to the current Caelestia colour scheme.
# Strategy:
#  1. Prefer a full base theme (adw-gtk3-dark / Adwaita-dark) so widgets are complete.
#  2. Inject Material You / libadwaita named colours into gtk-3.0 & gtk-4.0 gtk.css.
#  3. Keep gsettings + settings.ini consistent (previously mismatched → unreadable UI).
set -euo pipefail

SCHEME_JSON="${XDG_STATE_HOME:-$HOME/.local/state}/caelestia/scheme.json"
SCHEME_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/scheme/current.conf"
GTK3_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gtk-3.0"
GTK4_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gtk-4.0"
THEME_DIR="$HOME/.themes/Caelestia-Dark"

hex() {
    local c="${1:-000000}"
    c="${c#\#}"
    c="${c//\"/}"
    if [[ ${#c} -eq 3 ]]; then
        c="${c:0:1}${c:0:1}${c:1:1}${c:1:1}${c:2:1}${c:2:1}"
    fi
    printf '%s' "$c"
}

# shellcheck disable=SC2034
declare -A C=(
    [background]=0b0e11
    [onBackground]=e0e6ee
    [surface]=0b0e11
    [surfaceContainer]=151a1f
    [surfaceContainerLow]=101418
    [surfaceContainerHigh]=1b2025
    [surfaceContainerHighest]=20262c
    [onSurface]=e0e6ee
    [onSurfaceVariant]=a5acb3
    [outline]=70767d
    [outlineVariant]=42494f
    [primary]=a9cae8
    [onPrimary]=22435c
    [primaryContainer]=35566f
    [onPrimaryContainer]=cde6ff
    [secondary]=b8c8d9
    [onSecondary]=324250
    [secondaryContainer]=2d3d4b
    [error]=fa746f
    [onError]=490006
    [errorContainer]=871f21
    [scrim]=000000
    [shadow]=000000
)

load_from_json() {
    local json="$1"
    [[ -f "$json" ]] || return 1
    python3 - "$json" <<'PY' || return 1
import json, sys
path = sys.argv[1]
data = json.load(open(path))
colours = data.get("colours") or data.get("colors") or {}
keys = [
    "background","onBackground","surface","surfaceContainer","surfaceContainerLow",
    "surfaceContainerHigh","surfaceContainerHighest","onSurface","onSurfaceVariant",
    "outline","outlineVariant","primary","onPrimary","primaryContainer","onPrimaryContainer",
    "secondary","onSecondary","secondaryContainer","error","onError","errorContainer",
    "scrim","shadow",
]
for k in keys:
    v = colours.get(k)
    if v:
        print(f"{k}={str(v).lstrip('#')}")
PY
}

load_from_conf() {
    local conf="$1"
    [[ -f "$conf" ]] || return 1
    # $primary = a9cae8
    awk -F'[= ]+' '
        /^\$[A-Za-z0-9_]+/ {
            name=$1; sub(/^\$/,"",name);
            val=$NF; gsub(/#/,"",val);
            if (val ~ /^[0-9a-fA-F]{3,8}$/) print name"="val
        }
    ' "$conf"
}

apply_kv() {
    local line key val
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        key="${line%%=*}"
        val="${line#*=}"
        C["$key"]="$(hex "$val")"
    done
}

if kv="$(load_from_json "$SCHEME_JSON" 2>/dev/null)"; then
    apply_kv <<<"$kv"
elif kv="$(load_from_conf "$SCHEME_CONF" 2>/dev/null)"; then
    apply_kv <<<"$kv"
else
    echo "caelestia-gtk-sync: no scheme source found" >&2
    exit 1
fi

# Fallbacks for missing keys
: "${C[surfaceContainerLow]:=${C[surface]}}"
: "${C[surfaceContainerHighest]:=${C[surfaceContainerHigh]}}"
: "${C[onPrimaryContainer]:=${C[onSurface]}}"
: "${C[onError]:=ffffff}"
: "${C[errorContainer]:=${C[error]}}"
: "${C[scrim]:=000000}"
: "${C[shadow]:=000000}"

bg="${C[background]}"
fg="${C[onSurface]}"
fg_muted="${C[onSurfaceVariant]}"
surface="${C[surface]}"
surface_c="${C[surfaceContainer]}"
surface_high="${C[surfaceContainerHigh]}"
surface_highest="${C[surfaceContainerHighest]}"
surface_low="${C[surfaceContainerLow]}"
primary="${C[primary]}"
on_primary="${C[onPrimary]}"
primary_c="${C[primaryContainer]}"
on_primary_c="${C[onPrimaryContainer]}"
secondary="${C[secondary]}"
on_secondary="${C[onSecondary]}"
secondary_c="${C[secondaryContainer]}"
outline="${C[outline]}"
outline_v="${C[outlineVariant]}"
error="${C[error]}"
on_error="${C[onError]}"
error_c="${C[errorContainer]}"
scrim="${C[scrim]}"

# Pick a complete base theme if available (full widget coverage).
# Custom Caelestia-Dark alone is incomplete and causes unreadable stock controls.
base_theme=""
for candidate in adw-gtk3-dark Adwaita-dark Adwaita; do
    if [[ -d "$HOME/.themes/$candidate" || -d "/usr/share/themes/$candidate" ]]; then
        base_theme="$candidate"
        break
    fi
done
# Always keep a named theme for apps that only read gtk-theme-name.
active_theme="${base_theme:-Caelestia-Dark}"

write_named_theme() {
    local dir="$1"
    mkdir -p "$dir/gtk-3.0" "$dir/gtk-4.0"
    # index.theme so GTK discovers it as a real theme
    cat > "$dir/index.theme" <<EOF
[Desktop Entry]
Type=X-GNOME-Metatheme
Name=Caelestia-Dark
Comment=Generated from Caelestia scheme
Encoding=UTF-8

[X-GNOME-Metatheme]
GtkTheme=Caelestia-Dark
MetacityTheme=Adwaita
IconTheme=Papirus-Dark
CursorTheme=Adwaita
ButtonLayout=close,minimize,maximize:
EOF

    # Full-ish CSS for apps that select Caelestia-Dark directly.
    cat > "$dir/gtk-3.0/gtk.css" <<EOF
/* Caelestia-Dark — generated $(date -Iseconds) */
@define-color bg_color #${bg};
@define-color fg_color #${fg};
@define-color base_color #${surface};
@define-color text_color #${fg};
@define-color selected_bg_color #${primary};
@define-color selected_fg_color #${on_primary};
@define-color insensitive_bg_color #${surface_c};
@define-color insensitive_fg_color #${fg_muted};
@define-color borders #${outline_v};
@define-color warning_color #${error};
@define-color error_color #${error};
@define-color success_color #${secondary};

* {
    color: @fg_color;
    background-clip: padding-box;
}

window, .background, dialog, messagedialog, .csd {
    background-color: alpha(@bg_color, 0.82);
    color: @fg_color;
}

headerbar, .titlebar, .titlebar.default-decoration {
    background-color: alpha(#${surface_c}, 0.70);
    color: @fg_color;
    border-bottom: 1px solid alpha(#${outline_v}, 0.55);
    box-shadow: none;
    min-height: 40px;
}

headerbar button, .titlebar button {
    color: @fg_color;
    background-color: transparent;
    border: none;
    box-shadow: none;
}

headerbar button:hover, .titlebar button:hover {
    background-color: alpha(#${fg}, 0.08);
}

button {
    background-image: none;
    background-color: alpha(#${surface_high}, 0.78);
    color: @fg_color;
    border: 1px solid alpha(#${outline_v}, 0.70);
    border-radius: 8px;
    padding: 6px 12px;
    min-height: 28px;
    box-shadow: none;
    text-shadow: none;
}

button:hover {
    background-color: #${surface_highest};
}

button:active, button:checked, button.suggested-action {
    background-color: #${primary};
    color: #${on_primary};
    border-color: #${primary};
}

button.destructive-action {
    background-color: #${error};
    color: #${on_error};
    border-color: #${error};
}

button:disabled {
    color: @insensitive_fg_color;
    background-color: @insensitive_bg_color;
}

entry, textview, spinbutton, searchbar entry {
    background-image: none;
    background-color: alpha(#${surface_low}, 0.88);
    color: @fg_color;
    border: 1px solid alpha(#${outline_v}, 0.80);
    border-radius: 8px;
    padding: 6px 10px;
    box-shadow: none;
    caret-color: @fg_color;
}

entry:focus, textview:focus, spinbutton:focus {
    border-color: #${primary};
    box-shadow: 0 0 0 1px alpha(#${primary}, 0.35);
}

entry:disabled {
    color: @insensitive_fg_color;
    background-color: @insensitive_bg_color;
}

treeview, list, listview, iconview, .view, .content-view {
    background-color: alpha(#${surface}, 0.78);
    color: @fg_color;
}

row, list row, treeview.view {
    color: @fg_color;
    background-color: transparent;
}

row:hover, list row:hover {
    background-color: alpha(#${fg}, 0.06);
}

row:selected, list row:selected, treeview.view:selected,
.view:selected, iconview:selected {
    background-color: alpha(#${primary}, 0.22);
    color: @fg_color;
}

.sidebar, paned > .sidebar, stacksidebar, placessidebar {
    background-color: alpha(#${surface_c}, 0.68);
    color: @fg_color;
    border-right: 1px solid alpha(#${outline_v}, 0.55);
}

scrolledwindow, viewport {
    background-color: transparent;
}

scrollbar, scrollbar.vertical, scrollbar.horizontal {
    background-color: transparent;
}

scrollbar slider {
    background-color: alpha(#${fg}, 0.28);
    border-radius: 99px;
    min-width: 8px;
    min-height: 8px;
    margin: 2px;
}

scrollbar slider:hover {
    background-color: alpha(#${fg}, 0.45);
}

switch {
    background-color: alpha(#${fg}, 0.18);
    border-radius: 999px;
    border: none;
    min-width: 42px;
    min-height: 24px;
}

switch:checked {
    background-color: #${primary};
}

switch slider {
    background-color: #${fg};
    border-radius: 999px;
    min-width: 20px;
    min-height: 20px;
    margin: 2px;
}

switch:checked slider {
    background-color: #${on_primary};
}

scale trough {
    background-color: alpha(#${fg}, 0.16);
    border-radius: 999px;
    min-height: 6px;
}

scale highlight {
    background-color: #${primary};
    border-radius: 999px;
}

scale slider {
    background-color: #${fg};
    border: none;
    border-radius: 999px;
    min-width: 16px;
    min-height: 16px;
    box-shadow: none;
}

check, radio {
    background-color: #${surface_high};
    border: 2px solid #${outline};
    color: #${on_primary};
    min-width: 16px;
    min-height: 16px;
}

check:checked, radio:checked {
    background-color: #${primary};
    border-color: #${primary};
    color: #${on_primary};
}

menu, .menu, .context-menu {
    background-color: alpha(#${surface_c}, 0.78);
    color: @fg_color;
    border: 1px solid alpha(#${outline_v}, 0.65);
    border-radius: 12px;
    padding: 4px;
}

menuitem, modelbutton, .menuitem {
    color: @fg_color;
    border-radius: 6px;
    padding: 6px 12px;
    min-height: 24px;
}

menuitem:hover, modelbutton:hover, menuitem:selected {
    background-color: alpha(#${primary}, 0.18);
    color: @fg_color;
}

popover, popover.background, .popover {
    background-color: alpha(#${surface_high}, 0.80);
    color: @fg_color;
    border: 1px solid alpha(#${outline_v}, 0.60);
    border-radius: 14px;
    box-shadow: 0 10px 30px alpha(#${scrim}, 0.35);
}

tooltip, tooltip.background {
    background-color: alpha(#${surface_highest}, 0.88);
    color: @fg_color;
    border: 1px solid alpha(#${outline_v}, 0.55);
    border-radius: 10px;
    padding: 6px 10px;
}

notebook > header {
    background-color: alpha(#${surface_c}, 0.72);
    border-color: alpha(#${outline_v}, 0.55);
}

notebook > header > tabs > tab {
    background-color: transparent;
    color: #${fg_muted};
    border: none;
    padding: 8px 14px;
}

notebook > header > tabs > tab:checked {
    color: @fg_color;
    box-shadow: inset 0 -2px 0 #${primary};
}

notebook > stack {
    background-color: alpha(@bg_color, 0.82);
}

progressbar trough {
    background-color: alpha(#${fg}, 0.12);
    border-radius: 999px;
}

progressbar progress {
    background-color: #${primary};
    border-radius: 999px;
}

separator {
    background-color: alpha(#${outline_v}, 0.9);
    min-width: 1px;
    min-height: 1px;
}

label, .label {
    color: @fg_color;
}

label.dim-label, .dim-label {
    color: #${fg_muted};
    opacity: 1;
}

frame > border, .frame {
    border-color: #${outline_v};
}

/* Text selection */
selection, *:selected {
    background-color: alpha(#${primary}, 0.35);
    color: @fg_color;
}

/* Links */
link, .link {
    color: #${primary};
}
EOF
    cp "$dir/gtk-3.0/gtk.css" "$dir/gtk-4.0/gtk.css"
}

write_named_theme "$THEME_DIR"

# libadwaita / modern GTK named colours (works for GTK4 apps even without a full theme)
write_overlay_css() {
    local dest="$1"
    mkdir -p "$(dirname "$dest")"
    # Preserve optional thunar.css import if present nearby
    local thunar_import=""
    if [[ -f "$(dirname "$dest")/thunar.css" ]]; then
        thunar_import=$'@import "thunar.css";\n'
    fi
    cat > "$dest" <<EOF
/* Villode / Caelestia GTK overlay — generated $(date -Iseconds) */
/* Source: ${SCHEME_JSON:-$SCHEME_CONF} */

@define-color accent_color #${primary};
@define-color accent_bg_color #${primary};
@define-color accent_fg_color #${on_primary};
@define-color destructive_color #${error};
@define-color destructive_bg_color #${error};
@define-color destructive_fg_color #${on_error};
@define-color success_color #${secondary};
@define-color success_bg_color #${secondary_c};
@define-color success_fg_color #${on_secondary};
@define-color warning_color #${error};
@define-color warning_bg_color #${error_c};
@define-color warning_fg_color #${on_error};
@define-color error_color #${error};
@define-color error_bg_color #${error_c};
@define-color error_fg_color #${on_error};

@define-color window_bg_color alpha(#${bg}, 0.82);
@define-color window_fg_color #${fg};
@define-color view_bg_color alpha(#${surface}, 0.80);
@define-color view_fg_color #${fg};
@define-color headerbar_bg_color alpha(#${surface_c}, 0.70);
@define-color headerbar_fg_color #${fg};
@define-color headerbar_border_color #${outline_v};
@define-color headerbar_backdrop_color #${surface};
@define-color headerbar_shade_color alpha(#${scrim}, 0.25);
@define-color card_bg_color alpha(#${surface_c}, 0.78);
@define-color card_fg_color #${fg};
@define-color popover_bg_color alpha(#${surface_high}, 0.80);
@define-color popover_fg_color #${fg};
@define-color dialog_bg_color alpha(#${surface_c}, 0.84);
@define-color dialog_fg_color #${fg};
@define-color sidebar_bg_color alpha(#${surface_c}, 0.68);
@define-color sidebar_fg_color #${fg};
@define-color sidebar_border_color #${outline_v};
@define-color sidebar_backdrop_color #${surface};
@define-color secondary_sidebar_bg_color alpha(#${surface_low}, 0.72);
@define-color secondary_sidebar_fg_color #${fg};
@define-color secondary_sidebar_border_color #${outline_v};
@define-color secondary_sidebar_backdrop_color #${surface};

@define-color shade_color alpha(#${scrim}, 0.25);
@define-color scrollbar_outline_color alpha(#${scrim}, 0.5);

/* Legacy Adwaita names used by many GTK3 apps */
@define-color theme_bg_color @window_bg_color;
@define-color theme_fg_color @window_fg_color;
@define-color theme_base_color @view_bg_color;
@define-color theme_text_color @view_fg_color;
@define-color theme_selected_bg_color alpha(@accent_color, 0.28);
@define-color theme_selected_fg_color @window_fg_color;
@define-color theme_unfocused_bg_color @window_bg_color;
@define-color theme_unfocused_fg_color @window_fg_color;
@define-color theme_unfocused_base_color @view_bg_color;
@define-color theme_unfocused_text_color @view_fg_color;
@define-color theme_unfocused_selected_bg_color alpha(@accent_color, 0.18);
@define-color theme_unfocused_selected_fg_color @window_fg_color;
@define-color insensitive_bg_color #${surface_c};
@define-color insensitive_fg_color #${fg_muted};
@define-color insensitive_base_color #${surface_c};
@define-color borders #${outline_v};
@define-color unfocused_borders #${outline_v};
@define-color warning_color @warning_color;
@define-color error_color @error_color;
@define-color success_color @success_color;

/* Hard fixes + glass for common unreadable cases */
window, .background, dialog, messagedialog {
    background-color: @window_bg_color;
    color: @window_fg_color;
}

headerbar, .titlebar {
    background-color: @headerbar_bg_color;
}

.sidebar, paned > .sidebar, stacksidebar, placessidebar {
    background-color: @sidebar_bg_color;
}

menu, .menu, .context-menu, popover, popover.background {
    background-color: @popover_bg_color;
}


label, .label {
    color: @window_fg_color;
}

label.dim-label, .dim-label, .subtitle {
    color: #${fg_muted};
    opacity: 1;
}

/* Ensure text fields are never light-on-light / dark-on-dark */
entry, textview, textview text, spinbutton, search entry {
    background-color: alpha(#${surface_low}, 0.90);
    color: @window_fg_color;
    caret-color: @window_fg_color;
}

/* Menus / context menus */
menu, .menu, .context-menu, popover, popover.background {
    background-color: @popover_bg_color;
    color: @popover_fg_color;
}

menuitem, modelbutton {
    color: @popover_fg_color;
}

menuitem:hover, modelbutton:hover, menuitem:selected {
    background-color: alpha(@accent_color, 0.2);
    color: @window_fg_color;
}

/* Selection */
selection, *:selected, row:selected, list row:selected, treeview.view:selected {
    background-color: alpha(@accent_color, 0.28);
    color: @window_fg_color;
}

${thunar_import}
EOF
}

write_overlay_css "$GTK3_DIR/gtk.css"
write_overlay_css "$GTK4_DIR/gtk.css"

write_settings_ini() {
    local dir="$1"
    local theme="$2"
    mkdir -p "$dir"
    cat > "$dir/settings.ini" <<EOF
[Settings]
gtk-theme-name=${theme}
gtk-icon-theme-name=Papirus-Dark
gtk-cursor-theme-name=Adwaita
gtk-font-name=Sans 10
gtk-application-prefer-dark-theme=1
gtk-decoration-layout=icon:minimize,maximize,close
EOF
}

write_settings_ini "$GTK3_DIR" "$active_theme"
write_settings_ini "$GTK4_DIR" "$active_theme"

# gsettings (GNOME/GTK apps that ignore settings.ini)
if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface gtk-theme "$active_theme" 2>/dev/null || true
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
    gsettings set org.gnome.desktop.interface icon-theme Papirus-Dark 2>/dev/null || true
fi

# Notify running GTK apps (best-effort)
if command -v gdbus >/dev/null 2>&1; then
    gdbus call --session --dest org.gnome.Shell --object-path /org/gnome/Shell \
        --method org.gnome.Shell.Eval 'Meta.restart("Reloading theme")' >/dev/null 2>&1 || true
fi

echo "GTK synced → theme=${active_theme} primary=#${primary} bg=#${bg}"
if [[ -z "$base_theme" ]]; then
    echo "提示：未找到 adw-gtk3-dark/Adwaita-dark，已使用自带 Caelestia-Dark。" >&2
    echo "      安装完整主题可进一步改善兼容性：sudo pacman -S adw-gtk-theme" >&2
fi
